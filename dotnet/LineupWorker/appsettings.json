{
  "ConnectionStrings": {
    "Redis": "localhost:6379,abortConnect=false,connectTimeout=3000,syncTimeout=1000"
  },
  "Vorp": {
    "ArtifactPath":      "data/vorp.json",
    "TitularidadePath":  "data/titularidade.json"
  },
  "Worker": {
    "LineupTimeoutMinutes":    55,
    "VarianceWideningFactor":  1.35,
    "QueueCapacity":           512,
    "WatchdogIntervalSeconds": 60,
    "RedisStateTtlHours":      6
  },
  "MarketStateEngine": {
    "MinEdgePct":           0.02,
    "MaxEdgePct":           0.15,
    "KellyFraction":        0.25,
    "BetSignalChannel":     "bet_signals",
    "LatencyBudgetMs":      300
  },
  "Logging": {
    "LogLevel": {
      "Default":     "Information",
      "LineupWorker": "Debug"
    }
  }
}
